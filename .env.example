# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres connection string for LangGraph Saver
# IMPORTANT: Supabase new projects don't expose direct db.{ref}.supabase.co endpoint.
# Always use the Pooler URL from: Dashboard → Project Settings → Database → Connection string
#
# Local development (Session mode, port 5432, supports prepared statements):
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# Vercel deployment (Transaction mode, port 6543, requires prepare: false — auto-detected in code):
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Daytona (code sandbox)
DAYTONA_API_KEY=your-daytona-api-key
DAYTONA_SERVER_URL=https://app.daytona.io
# Custom image (built from daytona-image/Dockerfile, pushed to a container registry)
DAYTONA_IMAGE=ghcr.io/your-org/datellix-data-analysis:latest

# Vercel Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token

# LLM (fill in one based on your chosen provider)
OPENAI_API_KEY=sk-your-openai-key
# Optional: override default model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# GLM_API_KEY=your-glm-key
# GLM_MODEL=glm-4-plus

# Generic OpenAI-compatible provider (DeepSeek / Moonshot / Together / Groq / OpenRouter / vLLM / etc.)
# Set LLM_PROVIDER=openai-compat and fill in the three values below.
# OPENAI_COMPAT_BASE_URL=https://api.deepseek.com/v1
# OPENAI_COMPAT_API_KEY=sk-your-compat-key
# OPENAI_COMPAT_MODEL=deepseek-chat
# Optional: sampling temperature (default: 0)
# OPENAI_COMPAT_TEMPERATURE=0

# LLM provider selection: openai | anthropic | glm | openai-compat
LLM_PROVIDER=openai

# Cloudflare Turnstile (signup bot protection)
# Get keys at: https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=your-site-key
CLOUDFLARE_TURNSTILE_SECRET_KEY=your-secret-key

# Resend (transactional email — verification codes)
# Get key at: https://resend.com → API Keys
# From address domain must be verified in Resend dashboard
RESEND_API_KEY=re_your-resend-api-key

# ──────────────────────────────────────────────────────────────────────
# Rate Limiting (IP-based sliding window)
# ──────────────────────────────────────────────────────────────────────
# Limits are applied automatically by middleware.ts and the API routes.
#
# Two backends (auto-selected based on env vars):
#   1. In-memory Map (default when UPSTASH_REDIS_REST_URL is not set):
#      Works for single-instance deployments (local dev, single Vercel
#      function instance). Effective limit = `limit × instance_count` in
#      multi-instance serverless — fine for dev, not for prod.
#   2. Upstash Redis (auto-enabled when both vars below are set): shared
#      counter store so limits are enforced across ALL instances. Required
#      for Vercel / multi-instance serverless deployments.
#
# Get keys at: https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
#
# Default limits (configurable in src/lib/ratelimit/limiter.ts → LIMITS):
#   - OTP send:    3 per 5 min per IP+email
#   - OTP verify:  5 per 5 min per IP+email (brute force protection)
#   - Chat API:   20 per min per user
#   - Upload:     10 per min per IP
#   - Global API: 100 per min per IP (catch-all)

# ──────────────────────────────────────────────────────────────────────
# Internationalization (i18n)
# ──────────────────────────────────────────────────────────────────────
# Locales supported: en (default), zh, es
# Locale routing: /{locale}/... (localePrefix: "always")
# Negotiation: cookie (NEXT_LOCALE) → Accept-Language header → default
# Message files: src/messages/{locale}.json
# Add a new locale: see instructions in src/i18n/routing.ts
