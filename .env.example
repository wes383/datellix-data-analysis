# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Direct Postgres connection string for LangGraph Saver (Supabase Dashboard → Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Daytona (code sandbox)
DAYTONA_API_KEY=your-daytona-api-key
DAYTONA_SERVER_URL=https://app.daytona.io
# Custom image (built from daytona-image/Dockerfile, pushed to a container registry)
DAYTONA_IMAGE=ghcr.io/your-org/datellix-data-analysis:latest

# Vercel Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token

# LLM (fill in one based on your chosen provider)
OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# GLM_API_KEY=your-glm-key

# LLM provider selection: openai | anthropic | glm
LLM_PROVIDER=openai
